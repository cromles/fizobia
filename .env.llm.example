# Axium LLM — OpenAI uyumlu API (Groq ücretsiz katman önerilir)
# Sunucuda: bu satırları .env.server dosyasına ekleyin, sonra:
#   systemctl restart oam-ecosystem

# --- Groq (ücretsiz, hızlı) — https://console.groq.com ---
# OAM_LLM_API_KEY=gsk_...
# OAM_LLM_BASE_URL=https://api.groq.com/openai/v1
# OAM_LLM_MODEL=llama-3.1-8b-instant

# --- OpenAI ---
# OAM_LLM_API_KEY=sk-...
# OAM_LLM_BASE_URL=https://api.openai.com/v1
# OAM_LLM_MODEL=gpt-4o-mini

# --- OpenRouter (çok model) ---
# OAM_LLM_API_KEY=sk-or-...
# OAM_LLM_BASE_URL=https://openrouter.ai/api/v1
# OAM_LLM_MODEL=openai/gpt-4o-mini

# Anahtar yoksa sistem otomatik şablon modunda kalır (ücretsiz).
