# The Hub — sunucu kurulumu (domain yok, sadece IP)
# Kopyala: cp .env.server.example .env.server
# Sunucu IP'nizi yazın (örnek: 185.12.34.56)

OAM_GATEWAY_HOST=0.0.0.0
OAM_GATEWAY_PORT=8787
OAM_PUBLIC_BASE_URL=http://185.12.34.56:8787

OAM_HUB_DEMO=false
OAM_HUB_LIVE_INTERVAL=30
OAM_X402_ENABLED=true
OAM_X402_DEV_ACCEPT_PROOF=true
OAM_X402_MARKET_PULSE_PRICE=0.05

# Zinesh embed yoksa boş bırakılabilir; sadece Hub IP'si yeter
OAM_CORS_ORIGINS=http://185.12.34.56:8787,http://127.0.0.1:8787
OAM_EMBED_FRAME_ORIGINS=http://185.12.34.56:8787

# On-chain kapalı (domain/HTTPS olmadan demo için yeterli)
OAM_ONCHAIN_ENABLED=false
