# The Hub — sunucu kurulumu
# IP:  cp .env.server.example .env.server  → OAM_PUBLIC_BASE_URL=http://SUNUCU_IP:8787
# Domain (.tr): cp .env.domain.example .env.server  → docs/deploy-domain-tr.md

OAM_GATEWAY_HOST=0.0.0.0
OAM_GATEWAY_PORT=8787
OAM_PUBLIC_BASE_URL=http://SUNUCU_IP:8787

OAM_HUB_DEMO=false
OAM_HUB_LIVE_INTERVAL=30
OAM_X402_ENABLED=true
OAM_X402_DEV_ACCEPT_PROOF=true
OAM_X402_MARKET_PULSE_PRICE=0.05
OAM_X402_SENTIMENT_PRICE=0.04
OAM_X402_MESH_PROOF_PRICE=0.10

OAM_CORS_ORIGINS=http://SUNUCU_IP:8787,http://127.0.0.1:8787,https://zinesh.com
OAM_EMBED_FRAME_ORIGINS=http://SUNUCU_IP:8787,https://zinesh.com

# On-chain kapalı (domain/HTTPS olmadan demo için yeterli)
OAM_ONCHAIN_ENABLED=false
