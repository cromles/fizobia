# The Hub — sunucu kurulumu
# IP:  cp .env.server.example .env.server
# Domain (.tr): cp .env.domain.example .env.server  → docs/deploy-domain-tr.md

OAM_GATEWAY_HOST=0.0.0.0
OAM_GATEWAY_PORT=8787
OAM_PUBLIC_BASE_URL=http://89.47.113.150:8787

OAM_HUB_DEMO=false
OAM_HUB_LIVE_INTERVAL=30
OAM_X402_ENABLED=true
OAM_X402_DEV_ACCEPT_PROOF=true
OAM_X402_MARKET_PULSE_PRICE=0.05
OAM_X402_SENTIMENT_PRICE=0.04
OAM_X402_MESH_PROOF_PRICE=0.10
# Gerçek USDC (Base Sepolia) — tx_hash ile doğrulama için:
# OAM_X402_DEV_ACCEPT_PROOF=false
# OAM_X402_PAYEE_ADDRESS=0xYourTreasury
# OAM_X402_RPC_URL=https://sepolia.base.org
# OAM_X402_USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Zinesh embed yoksa boş bırakılabilir; sadece Hub IP'si yeter
OAM_CORS_ORIGINS=http://89.47.113.150:8787,http://127.0.0.1:8787
OAM_EMBED_FRAME_ORIGINS=http://89.47.113.150:8787

# On-chain kapalı (domain/HTTPS olmadan demo için yeterli)
OAM_ONCHAIN_ENABLED=false
