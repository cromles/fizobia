# Base Sepolia on-chain staking — yeni sunucuda .env.server ile birleştirin
# 1) npm install && npm run compile
# 2) DEPLOYER_PRIVATE_KEY=0x... bash scripts/deploy_base_sepolia.sh
# 3) Aşağıdaki değerleri .env.server dosyanıza ekleyin

OAM_ONCHAIN_ENABLED=true
OAM_ONCHAIN_REQUIRE_TX=true
OAM_ONCHAIN_CHAIN_ID=84532
OAM_ONCHAIN_RPC_URL=https://sepolia.base.org
OAM_ONCHAIN_DEPLOYMENT=deployments/sepolia.json

# Operatör cüzdanı — havuzlara on-chain ödül yatırır (fundRewards)
OAM_ONCHAIN_OPERATOR_KEY=

# x402 — gerçek zincir ödemeleri (dev proof kapatın)
OAM_X402_DEV_ACCEPT_PROOF=false
OAM_X402_RPC_URL=https://sepolia.base.org
OAM_X402_CHAIN_ID=84532
OAM_X402_USDC_CONTRACT=0x036CbD53842c5426634e7929541eC2318f3dCF7e
OAM_X402_PAYEE_ADDRESS=

# Hardhat deploy — .env.server'a ekleyebilirsiniz (gitignore'da).
# Güvenlik: deploy bittikten sonra satırı silmek veya .funding.key kullanmak daha iyi.
# DEPLOYER_PRIVATE_KEY=0x...
# OAM_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
