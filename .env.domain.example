# The Hub — .tr domain ile production
# cp .env.domain.example .env.server
# hub.sizindomain.tr → gerçek subdomain'inizi yazın

OAM_GATEWAY_HOST=0.0.0.0
OAM_GATEWAY_PORT=8787
# Nginx/Caddy arkasında HTTPS terminate ediyorsanız public URL https olmalı:
OAM_PUBLIC_BASE_URL=https://hub.sizindomain.tr

OAM_HUB_DEMO=false
OAM_HUB_LIVE_INTERVAL=30
OAM_X402_ENABLED=true
OAM_X402_DEV_ACCEPT_PROOF=true
OAM_X402_MARKET_PULSE_PRICE=0.05
OAM_X402_SENTIMENT_PRICE=0.04
OAM_X402_MESH_PROOF_PRICE=0.10

# CORS — domain + www (Zinesh ayrı domain ise onu da ekleyin)
OAM_CORS_ORIGINS=https://hub.sizindomain.tr,https://www.sizindomain.tr,https://zinesh.com
OAM_EMBED_FRAME_ORIGINS=https://www.sizindomain.tr,https://zinesh.com

# Gerçek USDC (HTTPS sonrası açın)
# OAM_X402_DEV_ACCEPT_PROOF=false
# OAM_X402_PAYEE_ADDRESS=0xYourTreasury
# OAM_ONCHAIN_ENABLED=true
