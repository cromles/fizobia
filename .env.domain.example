# The Hub — axium.com.tr (veya kendi .tr domain'iniz)
# cp .env.domain.example .env.server
# Zinesh (zinesh.com) ayrı sunucuda kalır — sadece CORS/embed izni verilir.

OAM_GATEWAY_HOST=0.0.0.0
OAM_GATEWAY_PORT=8787
OAM_PUBLIC_BASE_URL=https://axium.com.tr

OAM_HUB_DEMO=false
OAM_HUB_LIVE_INTERVAL=30
OAM_X402_ENABLED=true
OAM_X402_DEV_ACCEPT_PROOF=true
OAM_X402_MARKET_PULSE_PRICE=0.05
OAM_X402_SENTIMENT_PRICE=0.04
OAM_X402_MESH_PROOF_PRICE=0.10

OAM_CORS_ORIGINS=https://axium.com.tr,https://www.axium.com.tr,https://zinesh.com,https://www.zinesh.com
OAM_EMBED_FRAME_ORIGINS=https://axium.com.tr,https://zinesh.com

# Gerçek USDC (HTTPS sonrası açın)
# OAM_X402_DEV_ACCEPT_PROOF=false
# OAM_X402_PAYEE_ADDRESS=0xYourTreasury
# OAM_ONCHAIN_ENABLED=true
